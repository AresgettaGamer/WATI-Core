{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wati.example/schema/v1/recipes.schema.json",
  "title": "WATI Catalog Recipes v1",
  "type": "object",
  "required": ["schemaVersion", "sourceId", "recipes"],
  "properties": {
    "schemaVersion": {"const": 1},
    "sourceId": {"type": "string"},
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["shaped", "shapeless", "furnace", "brewing_mix", "brewing_container", "smithing_transform", "smithing_trim"]},
          "tags": {"type": "array", "items": {"type": "string"}},
          "sourcePath": {"type": "string"},
          "warnings": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
