{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wati.example/schema/v1/acquisition.schema.json",
  "title": "WATI Catalog Acquisition v1",
  "type": "object",
  "required": ["schemaVersion", "sourceId", "methods"],
  "properties": {
    "schemaVersion": {"const": 1},
    "sourceId": {"type": "string"},
    "coverage": {"type": "string"},
    "methods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "method", "sourceType", "source", "certainty"],
        "properties": {
          "target": {"type": "string"},
          "method": {"type": "string"},
          "sourceType": {"type": "string"},
          "source": {"type": "string"},
          "certainty": {"enum": ["confirmed", "probable", "manual"]},
          "details": {"type": "object"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
