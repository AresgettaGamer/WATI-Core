{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wati.example/schema/v1/content.schema.json",
  "title": "WATI Catalog Content v1",
  "type": "object",
  "required": ["schemaVersion", "sourceId", "items", "blocks", "entities"],
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["id", "type", "fallbackName", "internal"],
      "properties": {
        "id": {"type": "string", "pattern": "^[^:]+:.+$"},
        "type": {"enum": ["item", "block", "entity"]},
        "fallbackName": {"type": "string"},
        "localizationKey": {"type": ["string", "null"]},
        "category": {"type": "string"},
        "internal": {"type": "boolean"},
        "sourcePath": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "schemaVersion": {"const": 1},
    "sourceId": {"type": "string"},
    "items": {"type": "array", "items": {"$ref": "#/$defs/entry"}},
    "blocks": {"type": "array", "items": {"$ref": "#/$defs/entry"}},
    "entities": {"type": "array", "items": {"$ref": "#/$defs/entry"}}
  },
  "additionalProperties": true
}
